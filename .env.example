# Copy this to .env and fill in your values for local development.
# For deployed Databricks Apps, set these in the App UI environment settings
# or via the app.yaml.template placeholders.

LAKEBASE_ENDPOINT=projects/<your-project>/branches/production/endpoints/primary
LAKEBASE_DATABASE=databricks_postgres
FOOTBALL_DATA_TOKEN=<your-token-from-football-data.org>
ADMIN_EMAILS=<your-email@example.com>
PREDICTION_LOCK_BEFORE_KICKOFF_HOURS=1
WORLDCUP_DEV_CORS=true
WEB_CONCURRENCY=1
INIT_SCHEMA_ON_START=false

# Optional: direct Postgres URL for local dev (bypasses Lakebase OAuth)
# DATABASE_URL_OVERRIDE=postgresql://user:pass@localhost:5432/worldcup

# Optional: SQL warehouse ID for the AI/BI demo dashboard
# DASHBOARD_WAREHOUSE_ID=<your-warehouse-id>
